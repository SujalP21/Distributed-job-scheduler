generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationRole {
  OWNER
  MEMBER
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

enum QueueStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum RetryStrategy {
  FIXED
  LINEAR
  EXPONENTIAL
}

enum JobType {
  IMMEDIATE
  DELAYED
  SCHEDULED
  RECURRING
  BATCH
}

enum JobState {
  QUEUED
  SCHEDULED
  CLAIMED
  RUNNING
  COMPLETED
  FAILED
  RETRYING
  DEAD_LETTER
}

enum ExecutionStatus {
  CLAIMED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
  TIMED_OUT
}

enum WorkerStatus {
  ONLINE
  DRAINING
  OFFLINE
}

enum ScheduledJobStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
}

enum DeadLetterReason {
  MAX_RETRIES_EXCEEDED
  CANCELLED
  VALIDATION_FAILED
  WORKER_SHUTDOWN
  UNKNOWN
}

model User {
  id              String                   @id @default(cuid())
  email           String                   @unique
  name            String
  passwordHash    String
  deletedAt       DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  memberships     OrganizationMembership[]
  refreshTokens   RefreshToken[]
  createdProjects Project[]                @relation("ProjectCreator")
  createdJobs     Job[]                    @relation("JobCreator")

  @@index([email])
  @@index([deletedAt])
  @@map("users")
}

model Organization {
  id          String                   @id @default(cuid())
  name        String
  slug        String                   @unique
  deletedAt   DateTime?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  memberships OrganizationMembership[]
  projects    Project[]

  @@index([slug])
  @@index([deletedAt])
  @@map("organizations")
}

model OrganizationMembership {
  id             String           @id @default(cuid())
  userId         String
  organizationId String
  role           OrganizationRole @default(MEMBER)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId, role])
  @@map("organization_memberships")
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([revokedAt, expiresAt])
  @@map("refresh_tokens")
}

model Project {
  id             String            @id @default(cuid())
  organizationId String
  createdById    String?
  name           String
  slug           String
  description    String?
  status         ProjectStatus     @default(ACTIVE)
  deletedAt      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      User?             @relation("ProjectCreator", fields: [createdById], references: [id], onDelete: SetNull)
  retryPolicies  RetryPolicy[]
  queues         Queue[]
  jobs           Job[]
  scheduledJobs  ScheduledJob[]
  workers        Worker[]
  deadLetters    DeadLetterQueue[]

  @@unique([organizationId, slug])
  @@index([organizationId, status, deletedAt])
  @@index([createdById])
  @@map("projects")
}

model RetryPolicy {
  id               String         @id @default(cuid())
  projectId        String
  name             String
  strategy         RetryStrategy
  maxAttempts      Int            @default(3)
  baseDelaySeconds Int            @default(30)
  maxDelaySeconds  Int            @default(3600)
  jitterSeconds    Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  project          Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  queues           Queue[]
  jobs             Job[]
  scheduledJobs    ScheduledJob[]

  @@unique([projectId, name])
  @@index([projectId, strategy])
  @@map("retry_policies")
}

model Queue {
  id               String            @id @default(cuid())
  projectId        String
  retryPolicyId    String?
  name             String
  slug             String
  status           QueueStatus       @default(ACTIVE)
  concurrencyLimit Int               @default(5)
  priorityWeight   Int               @default(0)
  deletedAt        DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  project          Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  retryPolicy      RetryPolicy?      @relation(fields: [retryPolicyId], references: [id], onDelete: SetNull)
  jobs             Job[]
  scheduledJobs    ScheduledJob[]
  workers          Worker[]
  deadLetters      DeadLetterQueue[]

  @@unique([projectId, slug])
  @@index([projectId, status, deletedAt])
  @@index([retryPolicyId])
  @@index([status, deletedAt, priorityWeight])
  @@map("queues")
}

model Job {
  id                String           @id @default(cuid())
  projectId         String
  queueId           String
  retryPolicyId     String?
  createdById       String?
  claimedByWorkerId String?
  batchId           String?
  type              JobType
  state             JobState         @default(QUEUED)
  priority          Int              @default(0)
  payload           Json
  result            Json?
  errorMessage      String?
  attempts          Int              @default(0)
  maxAttempts       Int              @default(3)
  scheduledFor      DateTime?
  availableAt       DateTime         @default(now())
  lockedAt          DateTime?
  completedAt       DateTime?
  failedAt          DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  project           Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  queue             Queue            @relation(fields: [queueId], references: [id], onDelete: Cascade)
  retryPolicy       RetryPolicy?     @relation(fields: [retryPolicyId], references: [id], onDelete: SetNull)
  createdBy         User?            @relation("JobCreator", fields: [createdById], references: [id], onDelete: SetNull)
  claimedByWorker   Worker?          @relation("ClaimedJobs", fields: [claimedByWorkerId], references: [id], onDelete: SetNull)
  executions        JobExecution[]
  logs              JobLog[]
  deadLetter        DeadLetterQueue?

  @@index([queueId, state, availableAt, priority, createdAt])
  @@index([state, availableAt, attempts])
  @@index([projectId, state, createdAt])
  @@index([queueId, state, createdAt])
  @@index([retryPolicyId, state])
  @@index([claimedByWorkerId, state, lockedAt])
  @@index([batchId])
  @@map("jobs")
}

model JobExecution {
  id           String          @id @default(cuid())
  jobId        String
  workerId     String?
  attempt      Int
  status       ExecutionStatus @default(CLAIMED)
  startedAt    DateTime        @default(now())
  finishedAt   DateTime?
  durationMs   Int?
  errorMessage String?
  metadata     Json?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  job          Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)
  worker       Worker?         @relation(fields: [workerId], references: [id], onDelete: SetNull)
  logs         JobLog[]

  @@unique([jobId, attempt])
  @@index([jobId, startedAt])
  @@index([workerId, status, startedAt])
  @@index([status, startedAt])
  @@map("job_executions")
}

model Worker {
  id              String            @id @default(cuid())
  projectId       String
  queueId         String?
  name            String
  hostname        String?
  status          WorkerStatus      @default(ONLINE)
  concurrency     Int               @default(5)
  lastHeartbeatAt DateTime?
  registeredAt    DateTime          @default(now())
  shutdownAt      DateTime?
  metadata        Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  project         Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  queue           Queue?            @relation(fields: [queueId], references: [id], onDelete: SetNull)
  heartbeats      WorkerHeartbeat[]
  executions      JobExecution[]
  claimedJobs     Job[]             @relation("ClaimedJobs")

  @@index([projectId, status, lastHeartbeatAt])
  @@index([queueId, status, lastHeartbeatAt])
  @@index([lastHeartbeatAt, status])
  @@map("workers")
}

model WorkerHeartbeat {
  id          String       @id @default(cuid())
  workerId    String
  status      WorkerStatus
  activeJobs  Int          @default(0)
  capacity    Int          @default(0)
  heartbeatAt DateTime     @default(now())
  metadata    Json?
  createdAt   DateTime     @default(now())
  worker      Worker       @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId, heartbeatAt])
  @@index([heartbeatAt, status])
  @@map("worker_heartbeats")
}

model JobLog {
  id          String        @id @default(cuid())
  jobId       String
  executionId String?
  level       LogLevel      @default(INFO)
  message     String
  metadata    Json?
  createdAt   DateTime      @default(now())
  job         Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  execution   JobExecution? @relation(fields: [executionId], references: [id], onDelete: SetNull)

  @@index([jobId, createdAt])
  @@index([executionId, createdAt])
  @@index([level, createdAt])
  @@map("job_logs")
}

model ScheduledJob {
  id             String             @id @default(cuid())
  projectId      String
  queueId        String
  retryPolicyId  String?
  name           String
  jobType        JobType            @default(RECURRING)
  cronExpression String?
  timezone       String             @default("UTC")
  payload        Json
  status         ScheduledJobStatus @default(ACTIVE)
  nextRunAt      DateTime
  lastRunAt      DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  project        Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  queue          Queue              @relation(fields: [queueId], references: [id], onDelete: Cascade)
  retryPolicy    RetryPolicy?       @relation(fields: [retryPolicyId], references: [id], onDelete: SetNull)

  @@index([status, nextRunAt])
  @@index([queueId, status, nextRunAt])
  @@index([projectId, status])
  @@index([retryPolicyId])
  @@map("scheduled_jobs")
}

model DeadLetterQueue {
  id              String           @id @default(cuid())
  projectId       String
  queueId         String
  jobId           String           @unique
  reason          DeadLetterReason @default(UNKNOWN)
  failureMessage  String
  payloadSnapshot Json
  failedAt        DateTime         @default(now())
  createdAt       DateTime         @default(now())
  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  queue           Queue            @relation(fields: [queueId], references: [id], onDelete: Cascade)
  job             Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([queueId, failedAt])
  @@index([projectId, failedAt])
  @@index([reason, failedAt])
  @@map("dead_letter_queue")
}
