{
  "name": "@scheduler/backend",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "start": "node dist/server.js",
